              },
              "subtitle": {
                "type": [
                  "string",
                  "null"
                ]
              },
              "url": {
                "type": "string",
                "description": "TeSS event URL"
              },
              "organizer": {
                "type": [
                  "string",
                  "null"
                ],
                "description": "Event organizer"
              },
              "description": {
                "type": [
                  "string",
                  "null"
                ]
              },
              "start": {
                "type": [
                  "string",
                  "null"
                ],
                "description": "Start date (ISO format)"
              },
              "end": {
                "type": [
                  "string",
                  "null"
                ],
                "description": "End date (ISO format)"
              },
              "venue": {
                "type": [
                  "string",
                  "null"
                ]
              },
              "city": {
                "type": [
                  "string",
                  "null"
                ]
              },
              "country": {
                "type": [
                  "string",
                  "null"
                ]
              },
              "online": {
                "type": [
                  "boolean",
                  "null"
                ]
              },
              "cost_basis": {
                "type": [
                  "string",
                  "null"
                ],
                "description": "free, partly_free, or fee_based"
              },
              "scientific_topics": {
                "type": "array",
                "items": {
                  "type": "object"
                }
              },
              "fields": {
                "type": "array"
              },
              "keywords": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              }
            }
          }
        },
        {
          "type": "object",
          "properties": {
