                      "type": "string"
                    }
                  },
                  "deposition_date": {
                    "type": [
                      "string",
                      "null"
                    ]
                  },
                  "organism": {
                    "type": "array",
                    "items": {
                      "type": "string"
                    }
                  }
                }
              }
            },
            "metadata": {
              "type": "object",
              "properties": {
                "source": {
                  "type": "string"
                },
                "total_found": {
