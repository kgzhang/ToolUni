                },
                "formula": {
                  "type": [
                    "string",
                    "null"
                  ]
                },
                "weight": {
                  "type": [
                    "number",
                    "null"
                  ]
                },
                "compound_type": {
                  "type": [
                    "string",
                    "null"
                  ]
                },
                "inchi": {
                  "type": [
                    "string",
                    "null"
                  ]
                },
                "inchi_key": {
                  "type": [
                    "string",
                    "null"
                  ]
                },
                "smiles": {
                  "type": [
                    "string",
                    "null"
                  ]
                },
                "systematic_name": {
                  "type": [
                    "string",
                    "null"
                  ]
                }
              }
            },
            "metadata": {
              "type": "object",
              "properties": {
                "source": {
                  "type": "string"
                },
                "query": {
                  "type": "string"
                },
                "endpoint": {
                  "type": "string"
                }
              }
            }
          },
          "required": [
            "data"
          ]
        },
        {
          "type": "object",
          "properties": {
