[
  {
    "name": "NeuroVault_list_collections",
    "description": "List and browse neuroimaging statistical map collections from NeuroVault. Returns collections of brain images (fMRI, PET, EEG) contributed by researchers worldwide. Each collection contains metadata about the study, DOI, authors, and imaging parameters. NeuroVault hosts over 16,000 collections with 650,000+ brain images. Use limit and offset for pagination. Use this to discover available neuroimaging datasets for meta-analysis or to find specific studies.",
    "parameter": {
      "type": "object",
      "properties": {
        "limit": {
          "type": [
            "integer",
            "null"
          ],
          "description": "Maximum number of collections to return per page (default 10, max 100). Example: 10"
        },
        "offset": {
          "type": [
            "integer",
            "null"
          ],
          "description": "Number of collections to skip for pagination (default 0). Example: 20 to get page 3 with limit=10"
        },
        "format": {
          "type": [
            "string",
            "null"
          ],
          "description": "Response format. Must be 'json'. Default: 'json'"
        }
      },
      "required": []
    },
    "fields": {
      "endpoint": "https://neurovault.org/api/collections/",
      "params": {
        "format": "json"
      }
    },
    "type": "BaseRESTTool",
    "test_examples": [
      {
        "limit": 5
      },
      {
        "limit": 3,
        "offset": 10
      }
    ],
    "return_schema": {
      "oneOf": [
        {
          "type": "object",
          "description": "Paginated list of NeuroVault collections",
          "properties": {
            "count": {
              "type": "integer",
              "description": "Total number of collections available"
            },
            "next": {
              "type": [
                "string",
                "null"
              ],
              "description": "URL for the next page of results"
            },
            "previous": {
              "type": [
                "string",
                "null"
              ],
              "description": "URL for the previous page of results"
            },
            "results": {
              "type": "array",
              "description": "Array of collection objects",
              "items": {
                "type": "object",
                "properties": {
                  "id": {
                    "type": "integer",
                    "description": "Collection ID"
                  },
                  "name": {
                    "type": "string",
                    "description": "Collection name/title"
                  },
                  "DOI": {
                    "type": [
                      "string",
                      "null"
                    ],
                    "description": "Digital Object Identifier"
                  },
                  "owner_name": {
                    "type": "string"
                  },
                  "number_of_images": {
                    "type": "integer"
                  },
                  "description": {
                    "type": [
                      "string",
                      "null"
                    ]
                  },
                  "authors": {
                    "type": [
                      "string",
                      "null"
                    ]
                  },
                  "paper_url": {
                    "type": [
                      "string",
                      "null"
                    ]
                  },
                  "journal_name": {
                    "type": [
                      "string",
                      "null"
                    ]
                  },
                  "add_date": {
                    "type": "string"
                  }
                }
              }
            }
          }
        },
        {
          "type": "object",
          "properties": {
            "error": {
              "type": "string"
            }
          },
          "required": [
            "error"
          ]
        }
      ]
    }
  },
  {
    "name": "NeuroVault_get_collection",
    "description": "Get detailed metadata for a specific NeuroVault neuroimaging collection by its ID. Returns study details including title, DOI, authors, journal, imaging parameters (scanner, pulse sequence, field strength), study design information (number of subjects, experimental conditions), and number of statistical map images. Use collection IDs from NeuroVault_list_collections or NeuroVault website. Example: collection 457 is the Human Connectome Project overview with 48 brain images.",
    "parameter": {
      "type": "object",
      "properties": {
        "collection_id": {
          "type": "integer",
          "description": "NeuroVault collection ID number. Examples: 457 (Human Connectome Project), 1952 (BrainPedia with 6573 images)"
        }
      },
      "required": [
        "collection_id"
      ]
    },
    "fields": {
      "endpoint": "https://neurovault.org/api/collections/{collection_id}/",
      "params": {
        "format": "json"
      }
    },
    "type": "BaseRESTTool",
    "test_examples": [
      {
        "collection_id": 457
      },
      {
        "collection_id": 1952
      }
    ],
    "return_schema": {
      "oneOf": [
        {
          "type": "object",
          "description": "Detailed collection metadata",
          "properties": {
            "id": {
              "type": "integer",
              "description": "Collection ID"
            },
            "name": {
              "type": "string",
              "description": "Collection name/title"
            },
            "DOI": {
              "type": [
                "string",
                "null"
              ],
              "description": "Digital Object Identifier of the associated publication"
            },
            "owner_name": {
              "type": "string"
            },
            "number_of_images": {
              "type": "integer",
              "description": "Number of statistical map images in collection"
            },
            "description": {
              "type": [
                "string",
                "null"
              ],
              "description": "Study description"
            },
            "authors": {
              "type": [
                "string",
                "null"
              ]
            },
            "paper_url": {
              "type": [
                "string",
                "null"
              ]
            },
            "journal_name": {
              "type": [
                "string",
                "null"
              ]
            },
            "full_dataset_url": {
              "type": [
                "string",
                "null"
              ]
            },
            "type_of_design": {
              "type": [
                "string",
                "null"
              ],
              "description": "Experimental design type"
            },
            "number_of_imaging_runs": {
              "type": [
                "integer",
                "null"
              ]
            },
            "number_of_experimental_units": {
              "type": [
                "integer",
                "null"
              ]
            },
            "scanner_make": {
              "type": [
                "string",
                "null"
              ]
            },
            "scanner_model": {
              "type": [
                "string",
                "null"
              ]
            },
            "field_strength": {
              "type": [
                "number",
                "null"
              ],
              "description": "MRI field strength in Tesla"
            },
            "pulse_sequence": {
              "type": [
                "string",
                "null"
              ]
            },
            "software_package": {
              "type": [
                "string",
                "null"
              ],
              "description": "Analysis software used"
            },
            "software_version": {
              "type": [
                "string",
                "null"
              ]
            },
            "add_date": {
              "type": "string",
              "description": "Date collection was added"
            },
            "modify_date": {
              "type": "string"
            },
            "url": {
              "type": "string",
              "description": "URL to view collection on NeuroVault"
            },
            "download_url": {
              "type": "string",
              "description": "URL to download all images"
            }
          }
        },
        {
          "type": "object",
