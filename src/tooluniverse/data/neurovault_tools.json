  {
    "name": "NeuroVault_list_collection_images",
    "description": "List all statistical map images in a specific NeuroVault collection. Returns image metadata including name, map type (T map, Z map, F map, etc.), cognitive paradigm/contrast annotations, and file download URLs. Use this to explore what brain maps are available in a study collection before downloading. Example: collection 457 (Human Connectome Project) has 48 images covering emotion, gambling, language, motor, relational, social, and working memory tasks.",
    "parameter": {
      "type": "object",
      "properties": {
        "collection_id": {
          "type": "integer",
          "description": "NeuroVault collection ID. Example: 457 (Human Connectome Project)"
        },
        "limit": {
          "type": [
            "integer",
            "null"
          ],
          "description": "Maximum number of images to return (default 10, max 100)"
        },
        "offset": {
          "type": [
            "integer",
            "null"
          ],
          "description": "Number of images to skip for pagination (default 0)"
        }
      },
      "required": [
        "collection_id"
      ]
    },
    "fields": {
      "endpoint": "https://neurovault.org/api/collections/{collection_id}/images/",
      "params": {
        "format": "json"
      }
    },
    "type": "BaseRESTTool",
    "test_examples": [
      {
        "collection_id": 457,
        "limit": 5
      },
      {
        "collection_id": 1952,
        "limit": 3
      }
    ],
    "return_schema": {
      "oneOf": [
        {
          "type": "object",
          "description": "Paginated list of images in the collection",
          "properties": {
            "count": {
              "type": "integer",
              "description": "Total number of images"
            },
            "next": {
              "type": [
                "string",
                "null"
              ]
            },
            "previous": {
              "type": [
                "string",
                "null"
              ]
            },
            "results": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "id": {
                    "type": "integer",
                    "description": "Image ID"
                  },
                  "name": {
                    "type": "string",
                    "description": "Image name"
                  },
                  "map_type": {
                    "type": [
                      "string",
                      "null"
                    ],
                    "description": "Statistical map type: T map, Z map, F map, etc."
                  },
                  "file": {
                    "type": "string",
                    "description": "URL to download the NIfTI image file"
                  },
                  "collection_id": {
                    "type": "integer"
                  },
                  "cognitive_paradigm_cogatlas": {
                    "type": [
                      "string",
                      "null"
                    ],
                    "description": "Cognitive Atlas paradigm label"
                  },
                  "cognitive_paradigm_cogatlas_id": {
                    "type": [
                      "string",
                      "null"
                    ]
                  },
                  "cognitive_contrast_cogatlas": {
                    "type": [
                      "string",
                      "null"
                    ],
                    "description": "Cognitive Atlas contrast label"
                  },
                  "analysis_level": {
                    "type": [
                      "string",
                      "null"
                    ],
                    "description": "Analysis level: group or individual"
                  }
                }
              }
            }
          }
        },
        {
          "type": "object",
          "properties": {
            "error": {
              "type": "string"
            }
          },
          "required": [
            "error"
          ]
        }
      ]
    }
  },
  {
    "name": "NeuroVault_get_image",
    "description": "Get detailed metadata for a specific brain statistical map image in NeuroVault by image ID. Returns comprehensive information including map type (T/Z/F map), cognitive paradigm and contrast annotations from Cognitive Atlas, analysis level, modality, and file download URL (NIfTI format). Use image IDs from NeuroVault_list_collection_images. Example: image 3128 is a Z map of 'emotion processing fMRI task paradigm' showing FACES minus SHAPES contrast from the Human Connectome Project.",
    "parameter": {
      "type": "object",
      "properties": {
        "image_id": {
          "type": "integer",
          "description": "NeuroVault image ID. Examples: 3128 (HCP emotion task Z map), 946 (pain T map)"
        }
      },
      "required": [
        "image_id"
      ]
    },
    "fields": {
      "endpoint": "https://neurovault.org/api/images/{image_id}/",
      "params": {
        "format": "json"
      }
    },
    "type": "BaseRESTTool",
    "test_examples": [
      {
        "image_id": 3128
      },
      {
        "image_id": 946
      }
    ],
    "return_schema": {
      "oneOf": [
        {
          "type": "object",
          "description": "Detailed image metadata",
          "properties": {
            "id": {
              "type": "integer",
              "description": "Image ID"
            },
            "name": {
              "type": "string",
              "description": "Image name/description"
            },
            "file": {
              "type": "string",
              "description": "URL to download the NIfTI image file"
            },
            "collection_id": {
              "type": "integer",
              "description": "Parent collection ID"
            },
            "map_type": {
              "type": [
                "string",
                "null"
              ],
              "description": "Statistical map type: T map, Z map, F map, univariate-beta map, ROI/mask, parcellation, etc."
            },
            "cognitive_paradigm_cogatlas": {
              "type": [
                "string",
                "null"
              ],
              "description": "Cognitive Atlas paradigm label (e.g., 'emotion processing fMRI task paradigm')"
            },
            "cognitive_paradigm_cogatlas_id": {
              "type": [
                "string",
                "null"
              ],
              "description": "Cognitive Atlas paradigm ID"
            },
            "cognitive_contrast_cogatlas": {
              "type": [
                "string",
                "null"
              ],
              "description": "Cognitive Atlas contrast label"
            },
            "cognitive_contrast_cogatlas_id": {
              "type": [
                "string",
                "null"
              ]
            },
            "analysis_level": {
              "type": [
                "string",
                "null"
              ],
              "description": "Analysis level: group or individual"
            },
            "modality": {
              "type": [
                "string",
                "null"
              ],
              "description": "Imaging modality (fMRI-BOLD, PET, etc.)"
            },
            "image_type": {
              "type": [
                "string",
                "null"
              ],
              "description": "Image type (statistic_map, atlas, etc.)"
            },
            "statistic_parameters": {
              "type": [
                "number",
                "null"
              ]
            },
            "smoothness_fwhm": {
              "type": [
                "number",
                "null"
              ],
              "description": "Smoothing kernel FWHM in mm"
            },
            "brain_coverage": {
              "type": [
                "number",
                "null"
              ]
            },
            "not_mni": {
              "type": "boolean",
              "description": "Whether image is NOT in MNI space"
            }
          }
        },
        {
          "type": "object",
          "properties": {
            "error": {
              "type": "string"
            }
          },
          "required": [
            "error"
          ]
        }
      ]
    }
  }
]
