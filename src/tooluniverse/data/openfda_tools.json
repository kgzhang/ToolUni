  {
    "name": "OpenFDA_search_device_510k",
    "description": "Search the FDA 510(k) premarket notification database via openFDA. Contains clearances for medical devices through the 510(k) pathway (substantial equivalence). Returns device names, applicant companies, decision dates, advisory committee classifications, and FDA decision types. Useful for medical device research, competitive landscape analysis, and understanding regulatory pathways for specific device categories.",
    "parameter": {
      "type": "object",
      "properties": {
        "search": {
          "type": "string",
          "description": "Lucene query for 510(k) devices (e.g., 'device_name:stethoscope', 'applicant:siemens', 'decision_date_year:2023', 'advisory_committee_description:radiology')"
        },
        "limit": {
          "type": [
            "integer",
            "null"
          ],
          "description": "Maximum number of results (default 5, max 100)"
        }
      },
      "required": [
        "search"
      ]
    },
    "fields": {
      "endpoint": "https://api.fda.gov/device/510k.json"
    },
    "type": "BaseRESTTool",
    "test_examples": [
      {
        "search": "device_name:stethoscope",
        "limit": 3
      },
      {
        "search": "device_name:\"glucose monitor\"",
        "limit": 3
      },
      {
        "search": "device_name:catheter",
        "limit": 2
      }
    ],
    "return_schema": {
      "oneOf": [
        {
          "type": "object",
          "description": "FDA 510(k) premarket notification records",
          "properties": {
            "meta": {
              "type": "object"
            },
            "results": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "k_number": {
                    "type": "string",
                    "description": "510(k) accession number (e.g., 'K234567')"
                  },
                  "device_name": {
                    "type": "string",
                    "description": "Device trade name"
                  },
                  "applicant": {
                    "type": "string",
                    "description": "Applicant/company name"
                  },
                  "decision_date": {
                    "type": "string",
                    "description": "FDA decision date (YYYYMMDD)"
                  },
                  "decision_description": {
                    "type": "string",
                    "description": "FDA decision (e.g., 'SUBSTANTIALLY EQUIVALENT (SESE)')"
                  },
                  "advisory_committee_description": {
                    "type": "string",
                    "description": "Device panel (e.g., 'Radiology', 'Cardiovascular')"
                  },
                  "product_code": {
                    "type": "string",
                    "description": "FDA product code"
                  },
                  "statement_or_summary": {
                    "type": "string",
                    "description": "SE statement or summary flag"
                  }
                }
              }
            }
          }
        },
        {
          "type": "object",
          "properties": {
            "error": {
              "type": "string"
            }
          },
          "required": [
            "error"
          ]
        }
      ]
    }
  },
