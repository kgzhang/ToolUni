[
  {
    "type": "FAERSAnalyticsTool",
    "name": "FAERS_calculate_disproportionality",
    "description": "Calculate statistical disproportionality measures (ROR, PRR, IC) with 95% CI for drug-event pairs. Returns signal strength classification. Example: drug='ibuprofen', event='hepatotoxicity' → ROR=2.3 [1.8-2.9]. Use for pharmacovigilance signal detection.",
    "parameter": {
      "type": "object",
      "required": [
        "drug_name",
        "adverse_event"
      ],
      "properties": {
        "operation": {
          "const": "calculate_disproportionality",
          "description": "Operation type (fixed)"
        },
        "drug_name": {
          "type": "string",
          "description": "Generic drug name (e.g., 'IBUPROFEN', 'ATORVASTATIN')"
        },
        "adverse_event": {
          "type": "string",
          "description": "MedDRA Preferred Term (e.g., 'Hepatotoxicity', 'Myopathy')"
        }
      }
    },
    "return_schema": {
      "type": "object",
      "properties": {
        "status": {
          "type": "string",
          "enum": [
            "success",
            "error"
          ]
        },
        "drug_name": {
          "type": "string"
        },
        "adverse_event": {
          "type": "string"
        },
        "contingency_table": {
          "type": "object"
        },
        "metrics": {
          "type": "object"
        },
        "signal_detection": {
          "type": "object"
        },
        "note": {
          "type": "string"
        },
        "error": {
          "type": "string"
        }
      },
      "required": [
        "status"
      ]
    },
    "test_examples": [
      {
        "drug_name": "IBUPROFEN",
        "adverse_event": "Gastrointestinal haemorrhage"
      }
    ]
  },
  {
    "type": "FAERSAnalyticsTool",
    "name": "FAERS_stratify_by_demographics",
    "description": "Stratify adverse event reports by demographics (sex, age group, country). Returns counts and percentages by demographic group. Example: ibuprofen + GI bleeding stratified by sex → Female: 60%, Male: 40%. Use for subpopulation risk assessment.",
    "parameter": {
      "type": "object",
      "required": [
        "drug_name",
        "adverse_event"
      ],
      "properties": {
        "operation": {
          "const": "stratify_by_demographics",
          "description": "Operation type (fixed)"
        },
        "drug_name": {
          "type": "string",
          "description": "Generic drug name"
        },
        "adverse_event": {
          "type": "string",
          "description": "MedDRA Preferred Term"
        },
        "stratify_by": {
          "type": "string",
          "enum": [
            "sex",
            "age",
            "country"
          ],
          "default": "sex",
          "description": "Demographic dimension to stratify by"
        }
      }
    },
    "return_schema": {
      "type": "object",
      "properties": {
        "status": {
          "type": "string",
          "enum": [
            "success",
            "error"
          ]
        },
        "drug_name": {
          "type": "string"
        },
        "adverse_event": {
          "type": "string"
        },
        "stratified_by": {
          "type": "string"
        },
        "total_reports": {
          "type": "integer"
        },
        "stratification": {
          "type": "array"
        },
        "error": {
          "type": "string"
        }
      },
      "required": [
        "status"
      ]
    },
    "test_examples": [
      {
        "drug_name": "IBUPROFEN",
        "adverse_event": "Gastrointestinal haemorrhage",
        "stratify_by": "sex"
      }
    ]
  },
  {
    "type": "FAERSAnalyticsTool",
    "name": "FAERS_filter_serious_events",
    "description": "Filter for serious adverse events (death, hospitalization, disability, life-threatening). Returns top reactions meeting seriousness criteria. Example: fulvestrant serious events → Death: 150 cases, Hospitalization: 500 cases. Use for risk-benefit assessment.",
    "parameter": {
      "type": "object",
      "required": [
        "drug_name"
      ],
      "properties": {
        "operation": {
          "const": "filter_serious_events",
          "description": "Operation type (fixed)"
        },
        "drug_name": {
          "type": "string",
          "description": "Generic drug name"
        },
        "seriousness_type": {
          "type": "string",
          "enum": [
            "all",
            "death",
            "hospitalization",
            "disability",
            "life_threatening"
          ],
          "default": "all",
          "description": "Type of serious event to filter"
        }
      }
    },
    "return_schema": {
      "type": "object",
      "properties": {
        "status": {
          "type": "string",
          "enum": [
            "success",
            "error"
          ]
        },
        "drug_name": {
          "type": "string"
        },
        "seriousness_type": {
          "type": "string"
        },
        "total_serious_events": {
          "type": "integer"
        },
        "top_serious_reactions": {
          "type": "array"
        },
        "note": {
          "type": "string"
        },
        "error": {
          "type": "string"
        }
      },
      "required": [
        "status"
      ]
    },
    "test_examples": [
      {
        "drug_name": "IBUPROFEN",
        "seriousness_type": "all"
      }
    ]
  },
  {
    "type": "FAERSAnalyticsTool",
    "name": "FAERS_compare_drugs",
    "description": "Compare safety signals for two drugs with the same adverse event. Returns ROR/PRR/IC for both drugs with comparative analysis. Example: compare fulvestrant vs tamoxifen for hepatotoxicity. Use for safety benchmarking.",
    "parameter": {
      "type": "object",
      "required": [
        "drug1",
        "drug2",
        "adverse_event"
      ],
      "properties": {
        "operation": {
          "const": "compare_drugs",
          "description": "Operation type (fixed)"
        },
        "drug1": {
          "type": "string",
          "description": "First drug name (generic)"
        },
        "drug2": {
          "type": "string",
          "description": "Second drug name (generic)"
        },
        "adverse_event": {
          "type": "string",
          "description": "MedDRA Preferred Term to compare"
        }
      }
    },
    "return_schema": {
      "type": "object",
      "properties": {
        "status": {
          "type": "string",
          "enum": [
            "success",
            "error"
          ]
        },
        "adverse_event": {
          "type": "string"
        },
        "drug1": {
          "type": "object"
        },
        "drug2": {
          "type": "object"
        },
        "comparison": {
          "type": "string"
        },
        "note": {
          "type": "string"
        },
        "error": {
          "type": "string"
        }
      },
      "required": [
        "status"
      ]
    },
    "test_examples": [
      {
        "drug1": "IBUPROFEN",
        "drug2": "NAPROXEN",
        "adverse_event": "Gastrointestinal haemorrhage"
      }
    ]
  },
  {
    "type": "FAERSAnalyticsTool",
    "name": "FAERS_analyze_temporal_trends",
    "description": "Analyze temporal trends in adverse event reporting by year. Returns yearly counts and trend direction (increasing/decreasing/stable). Example: ibuprofen GI bleeding reports 2015-2025 → +25% increase. Use for signal evolution monitoring.",
    "parameter": {
      "type": "object",
      "required": [
        "drug_name"
      ],
      "properties": {
        "operation": {
          "const": "analyze_temporal_trends",
          "description": "Operation type (fixed)"
        },
        "drug_name": {
          "type": "string",
          "description": "Generic drug name"
        },
        "adverse_event": {
          "type": "string",
          "description": "MedDRA Preferred Term (optional, omit for all events)"
        }
      }
    },
    "return_schema": {
      "type": "object",
      "properties": {
        "status": {
          "type": "string",
          "enum": [
            "success",
            "error"
          ]
        },
        "drug_name": {
          "type": "string"
        },
        "adverse_event": {
          "type": "string"
        },
        "temporal_data": {
          "type": "array"
        },
        "trend_analysis": {
          "type": "object"
        },
        "note": {
          "type": "string"
        },
        "error": {
          "type": "string"
        }
      },
      "required": [
        "status"
      ]
    },
    "test_examples": [
      {
        "drug_name": "IBUPROFEN",
        "adverse_event": "Gastrointestinal haemorrhage"
      }
    ]
  },
  {
    "type": "FAERSAnalyticsTool",
    "name": "FAERS_rollup_meddra_hierarchy",
    "description": "Aggregate adverse events by MedDRA hierarchy (Preferred Term level). Returns top 50 PTs with counts. Note: Full HLT/SOC hierarchy requires MedDRA license. Use for adverse event profile overview.",
    "parameter": {
      "type": "object",
      "required": [
        "drug_name"
      ],
      "properties": {
        "operation": {
          "const": "rollup_meddra_hierarchy",
          "description": "Operation type (fixed)"
        },
        "drug_name": {
          "type": "string",
          "description": "Generic drug name"
        }
      }
    },
    "return_schema": {
      "type": "object",
      "properties": {
        "status": {
          "type": "string",
          "enum": [
            "success",
            "error"
          ]
        },
        "drug_name": {
          "type": "string"
        },
        "meddra_hierarchy": {
          "type": "object"
        },
        "note": {
          "type": "string"
        },
        "recommendation": {
          "type": "string"
        },
        "error": {
          "type": "string"
        }
      },
      "required": [
        "status"
      ]
    },
    "test_examples": [
      {
        "drug_name": "IBUPROFEN"
      }
    ]
  }
]
