[
  {
    "name": "USGSWater_get_streamflow",
    "description": "Get real-time streamflow (discharge) data from USGS water monitoring stations. Returns instantaneous values for water flow rate in cubic feet per second (ft3/s) including site name, location coordinates, and recent measurements. The USGS monitors over 10,000 stream gauges across the United States.",
    "parameter": {
      "type": "object",
      "properties": {
        "sites": {
          "type": "string",
          "description": "USGS site number(s), comma-separated (e.g., '01646500' for Potomac River near Washington DC, '09380000' for Colorado River at Lees Ferry)"
        },
        "period": {
          "type": [
            "string",
            "null"
          ],
          "description": "Time period for data in ISO 8601 duration format (e.g., 'PT2H' for 2 hours, 'P1D' for 1 day, 'P7D' for 7 days). Default: 'P1D'"
        }
      },
      "required": [
        "sites"
      ]
    },
    "fields": {
      "endpoint": "https://waterservices.usgs.gov/nwis/iv/",
      "params": {
        "format": "json",
        "parameterCd": "00060"
      }
    },
    "type": "BaseRESTTool",
    "test_examples": [
      {
        "sites": "01646500",
        "period": "PT2H"
      },
      {
        "sites": "09380000",
        "period": "P1D"
      },
      {
        "sites": "12340000",
        "period": "PT6H"
      }
    ],
    "return_schema": {
      "oneOf": [
        {
          "type": "object",
          "description": "USGS water data response",
          "properties": {
            "name": {
              "type": "string"
            },
            "declaredType": {
              "type": "string"
            },
            "value": {
              "type": "object",
              "properties": {
                "queryInfo": {
                  "type": "object"
                },
                "timeSeries": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "properties": {
                      "sourceInfo": {
                        "type": "object",
                        "properties": {
                          "siteName": {
                            "type": "string"
                          },
                          "siteCode": {
                            "type": "array"
                          },
                          "geoLocation": {
                            "type": "object"
                          }
                        }
                      },
                      "variable": {
                        "type": "object",
                        "properties": {
                          "variableName": {
                            "type": "string"
                          },
                          "unit": {
                            "type": "object"
                          }
                        }
                      },
                      "values": {
                        "type": "array",
                        "items": {
                          "type": "object",
                          "properties": {
                            "value": {
                              "type": "array",
                              "items": {
                                "type": "object",
                                "properties": {
                                  "value": {
                                    "type": "string"
                                  },
                                  "dateTime": {
                                    "type": "string"
                                  }
                                }
                              }
                            }
                          }
                        }
                      }
                    }
                  }
                }
              }
            }
          }
        },
        {
          "type": "object",
          "properties": {
            "error": {
              "type": "string"
            }
          },
          "required": [
            "error"
          ]
        }
      ]
    }
  },
  {
