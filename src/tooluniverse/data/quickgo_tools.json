                    "string",
                    "null"
                  ],
                  "description": "GO term definition text"
                },
                "aspect": {
                  "type": [
                    "string",
                    "null"
                  ],
                  "description": "GO aspect (biological_process, etc.)"
                },
                "is_obsolete": {
                  "type": "boolean",
                  "description": "Whether the term is obsolete"
                },
                "synonyms": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "properties": {
                      "name": {
                        "type": [
                          "string",
                          "null"
                        ]
                      },
                      "type": {
                        "type": [
                          "string",
                          "null"
                        ]
                      }
                    }
                  }
                },
                "xrefs": {
                  "type": "array",
                  "items": {
