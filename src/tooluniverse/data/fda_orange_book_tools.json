[
  {
    "type": "FDAOrangeBookTool",
    "name": "FDA_OrangeBook_search_drug",
    "description": "Search FDA Drugs@FDA database by brand name, generic name, or application number. Returns approval status, products, and basic regulatory info. Example: brand_name='ADVIL' finds all Advil products with NDA numbers.",
    "parameter": {
      "type": "object",
      "required": [],
      "properties": {
        "operation": {
          "const": "search_drug",
          "description": "Operation type (fixed)"
        },
        "brand_name": {
          "type": "string",
          "description": "Brand/trade name of drug (e.g., 'ADVIL', 'LIPITOR')"
        },
        "generic_name": {
          "type": "string",
          "description": "Generic/active ingredient name (e.g., 'IBUPROFEN', 'ATORVASTATIN')"
        },
        "application_number": {
          "type": "string",
          "description": "FDA application number (e.g., 'NDA020402', 'ANDA078394')"
        },
        "limit": {
          "type": "integer",
          "description": "Maximum number of results (1-100, default 10)",
          "minimum": 1,
          "maximum": 100,
          "default": 10
        }
      }
    },
    "return_schema": {
      "type": "object",
      "properties": {
        "drugs": {
          "type": "array"
        },
        "count": {
          "type": "integer"
        },
        "total": {
          "type": "integer"
        }
      }
    },
    "test_examples": [
      {
        "brand_name": "ADVIL",
        "limit": 5
      }
    ]
  },
  {
    "type": "FDAOrangeBookTool",
    "name": "FDA_OrangeBook_get_approval_history",
    "description": "Get complete approval history for a drug application including original approval date, supplements, and review documents. Returns submission timeline and links to approval letters/labels. Example: NDA020402 shows all Advil approval actions.",
    "parameter": {
      "type": "object",
      "required": [
        "application_number"
      ],
      "properties": {
        "operation": {
          "const": "get_approval_history",
          "description": "Operation type (fixed)"
        },
        "application_number": {
          "type": "string",
          "description": "FDA application number (e.g., 'NDA020402')"
        }
      }
    },
    "return_schema": {
      "type": "object",
      "properties": {
        "application_number": {
          "type": "string"
        },
        "sponsor_name": {
          "type": "string"
        },
        "original_approval_date": {
          "type": "string"
        },
        "submissions": {
          "type": "array"
        },
        "submission_count": {
          "type": "integer"
        }
      }
    },
    "test_examples": [
      {
        "application_number": "NDA020402"
      }
    ]
  },
