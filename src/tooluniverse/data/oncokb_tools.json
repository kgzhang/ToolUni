    "parameter": {
      "type": "object",
      "properties": {
        "operation": {
          "type": "string",
          "const": "get_cancer_genes",
          "description": "Operation type (fixed: get_cancer_genes)"
        }
      },
      "required": []
    },
    "return_schema": {
      "type": "object",
      "properties": {
        "status": {
          "type": "string"
        },
        "data": {
          "type": "object",
          "properties": {
            "total_genes": {
              "type": "integer",
              "description": "Total genes in database"
            },
            "cancer_genes_count": {
              "type": "integer",
              "description": "Number of cancer-related genes"
            },
            "genes": {
              "type": "array",
              "description": "List of cancer genes with classifications"
            }
          }
        }
      }
    },
    "test_examples": [
      {}
    ]
  },
  {
    "name": "OncoKB_get_levels",
    "description": "Get OncoKB evidence level definitions. Returns descriptions of all therapeutic actionability levels (1, 2, 3A, 3B, 4, R1, R2). Level 1 = FDA-approved, Level 2 = Standard care, Level 3A = Compelling clinical evidence, etc.",
    "type": "OncoKBTool",
    "parameter": {
      "type": "object",
      "properties": {
        "operation": {
          "type": "string",
          "const": "get_levels",
          "description": "Operation type (fixed: get_levels)"
        }
      },
      "required": []
    },
    "return_schema": {
      "type": "object",
      "properties": {
        "status": {
          "type": "string"
        },
        "data": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "level": {
                "type": "string",
                "description": "Level code (LEVEL_1, LEVEL_2, etc.)"
              },
              "description": {
                "type": "string",
                "description": "Level description"
              }
            }
          }
        }
      }
    },
    "test_examples": [
      {}
    ]
  },
  {
    "name": "OncoKB_annotate_copy_number",
    "description": "Annotate copy number alterations (amplification/deletion) for oncogenic potential. Returns evidence for gene amplification or deletion in cancer. Example: ERBB2 amplification in breast cancer, CDKN2A deletion.",
    "type": "OncoKBTool",
    "parameter": {
      "type": "object",
      "properties": {
        "operation": {
          "type": "string",
          "const": "annotate_copy_number",
          "description": "Operation type (fixed: annotate_copy_number)"
        },
        "gene": {
          "type": "string",
          "description": "Gene symbol (e.g., ERBB2, MYC, CDKN2A)"
        },
        "copy_number_type": {
          "type": "string",
          "enum": [
            "AMPLIFICATION",
            "DELETION"
          ],
          "description": "Type of copy number alteration"
        },
        "tumor_type": {
          "type": "string",
          "description": "Optional OncoTree tumor type code"
        }
      },
      "required": [
        "gene",
        "copy_number_type"
      ]
    },
    "return_schema": {
      "type": "object",
      "properties": {
        "status": {
          "type": "string"
        },
        "data": {
          "type": "object",
          "properties": {
            "oncogenic": {
              "type": "string"
            },
            "highestSensitiveLevel": {
              "type": "string"
            },
            "treatments": {
              "type": "array"
            }
          }
        }
      }
    },
    "test_examples": [
      {
        "gene": "ERBB2",
        "copy_number_type": "AMPLIFICATION"
      }
    ]
  }
]
