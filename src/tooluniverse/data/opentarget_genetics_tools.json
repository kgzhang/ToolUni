  {
    "name": "OpenTargets_search_gwas_studies_by_disease",
    "description": "Search for GWAS studies associated with a disease or trait in Open Targets. Takes disease ontology IDs (EFO, MONDO) and returns matching GWAS studies with their metadata including sample sizes, traits, publications, and associated diseases. Use enableIndirect=true to include child disease terms.",
    "label": [
      "GWAS",
      "Study",
      "Disease",
      "Search",
      "Open Targets"
    ],
    "parameter": {
      "type": "object",
      "properties": {
        "diseaseIds": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "Disease ontology IDs (e.g., ['MONDO_0005148'] for type 2 diabetes, ['MONDO_0004975'] for Alzheimer disease)"
        },
        "enableIndirect": {
          "type": "boolean",
          "description": "Include studies for child disease terms (default true)",
          "default": true
        },
        "size": {
          "type": "integer",
          "description": "Number of results per page (default 10)",
          "default": 10
        },
        "index": {
          "type": "integer",
          "description": "Page index for pagination (0-based, default 0)",
          "default": 0
        }
      },
      "required": [
        "diseaseIds"
      ]
    },
    "query_schema": "\nquery searchStudies($diseaseIds: [String!], $enableIndirect: Boolean = true, $size: Int = 10, $index: Int = 0) {\n  studies(diseaseIds: $diseaseIds, enableIndirect: $enableIndirect, page: {size: $size, index: $index}) {\n    count\n    rows {\n      id\n      studyType\n      traitFromSource\n      publicationFirstAuthor\n      publicationTitle\n      publicationDate\n      pubmedId\n      nSamples\n      nCases\n      nControls\n      hasSumstats\n      diseases {\n        id\n        name\n      }\n    }\n  }\n}\n",
    "type": "OpenTarget",
    "test_examples": [
      {
        "diseaseIds": [
          "MONDO_0005148"
        ],
        "size": 5
      },
      {
        "diseaseIds": [
          "MONDO_0004975"
        ],
        "enableIndirect": true,
        "size": 5
      }
    ],
    "return_schema": {
      "oneOf": [
        {
          "type": "object",
          "properties": {
            "data": {
              "type": "object",
              "properties": {
                "studies": {
                  "type": "object",
                  "properties": {
                    "count": {
                      "type": "integer"
                    },
                    "rows": {
                      "type": "array",
                      "items": {
                        "type": "object",
                        "properties": {
                          "id": {
                            "type": "string"
                          },
                          "studyType": {
                            "type": [
                              "string",
                              "null"
                            ]
                          },
                          "traitFromSource": {
                            "type": [
                              "string",
                              "null"
                            ]
                          },
                          "publicationFirstAuthor": {
                            "type": [
                              "string",
                              "null"
                            ]
                          },
                          "publicationTitle": {
                            "type": [
                              "string",
                              "null"
                            ]
                          },
                          "publicationDate": {
                            "type": [
                              "string",
                              "null"
                            ]
                          },
                          "pubmedId": {
                            "type": [
                              "string",
                              "null"
                            ]
                          },
                          "nSamples": {
                            "type": [
                              "integer",
                              "null"
                            ]
                          },
                          "nCases": {
                            "type": [
                              "integer",
                              "null"
                            ]
                          },
                          "nControls": {
                            "type": [
                              "integer",
                              "null"
                            ]
                          },
                          "hasSumstats": {
                            "type": [
                              "boolean",
                              "null"
                            ]
                          },
                          "diseases": {
                            "type": "array",
                            "items": {
                              "type": "object",
                              "properties": {
                                "id": {
                                  "type": "string"
                                },
                                "name": {
                                  "type": "string"
                                }
