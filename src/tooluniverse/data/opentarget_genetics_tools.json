[
  {
    "name": "OpenTargets_get_variant_info",
    "description": "Get detailed information about a genetic variant from Open Targets Platform, including genomic coordinates, rsIDs, allele frequencies across populations (gnomAD), functional consequence, transcript consequences, and HGVS notation. Useful for GWAS variant annotation and population genetics.",
    "label": [
      "GWAS",
      "Variant",
      "Genetics",
      "Open Targets"
    ],
    "parameter": {
      "type": "object",
      "properties": {
        "variantId": {
          "type": "string",
          "description": "Open Targets variant ID in format chr_position_ref_alt (e.g., '10_112998590_C_T' for rs7903146, '19_44908684_T_C' for rs429358). Use the search tool to find variant IDs from rsIDs."
        }
      },
      "required": [
        "variantId"
      ]
    },
    "query_schema": "\nquery variantInfo($variantId: String!) {\n  variant(variantId: $variantId) {\n    id\n    rsIds\n    chromosome\n    position\n    referenceAllele\n    alternateAllele\n    hgvsId\n    variantDescription\n    mostSevereConsequence {\n      id\n      label\n    }\n    alleleFrequencies {\n      populationName\n      alleleFrequency\n    }\n  }\n}\n",
    "type": "OpenTarget",
    "test_examples": [
      {
        "variantId": "10_112998590_C_T"
      },
      {
        "variantId": "19_44908684_T_C"
      }
    ],
    "return_schema": {
      "oneOf": [
        {
          "type": "object",
          "properties": {
            "data": {
              "type": "object",
              "properties": {
                "variant": {
                  "type": "object",
                  "properties": {
                    "id": {
                      "type": "string",
                      "description": "Variant identifier in chr_pos_ref_alt format"
                    },
                    "rsIds": {
                      "type": "array",
                      "items": {
                        "type": "string"
                      },
                      "description": "dbSNP rs identifiers"
                    },
                    "chromosome": {
                      "type": "string"
                    },
                    "position": {
                      "type": "integer"
                    },
                    "referenceAllele": {
                      "type": "string"
                    },
                    "alternateAllele": {
                      "type": "string"
                    },
                    "hgvsId": {
                      "type": [
                        "string",
                        "null"
                      ],
                      "description": "HGVS notation"
                    },
                    "variantDescription": {
                      "type": "string",
                      "description": "Human-readable variant description"
                    },
                    "mostSevereConsequence": {
                      "type": "object",
                      "properties": {
                        "id": {
                          "type": "string"
                        },
                        "label": {
                          "type": "string"
                        }
                      }
                    },
                    "alleleFrequencies": {
                      "type": "array",
                      "items": {
                        "type": "object",
                        "properties": {
                          "populationName": {
                            "type": "string"
                          },
                          "alleleFrequency": {
                            "type": "number"
                          }
                        }
                      }
                    }
                  }
                }
              }
            }
          },
          "required": [
            "data"
          ]
        },
        {
          "type": "object",
          "properties": {
            "error": {
              "type": "object"
            }
          },
          "required": [
            "error"
          ]
        }
      ]
    }
  },
  {
    "name": "OpenTargets_get_variant_credible_sets",
    "description": "Get GWAS credible sets (fine-mapped loci) associated with a genetic variant from Open Targets. Returns studies where this variant appears in a fine-mapped credible set, with locus-to-gene (L2G) predictions, p-values, effect sizes, and the fine-mapping method used. Essential for understanding which GWAS signals a variant is part of and which genes it likely affects.",
    "label": [
      "GWAS",
      "Fine-mapping",
      "Credible Set",
      "Variant",
      "Open Targets"
    ],
    "parameter": {
      "type": "object",
      "properties": {
        "variantId": {
          "type": "string",
          "description": "Open Targets variant ID in format chr_position_ref_alt (e.g., '10_112998590_C_T' for rs7903146)"
        },
        "size": {
          "type": "integer",
          "description": "Number of credible sets to return (default 10)",
          "default": 10
        }
      },
      "required": [
        "variantId"
      ]
    },
    "query_schema": "\nquery variantCredibleSets($variantId: String!, $size: Int = 10, $index: Int = 0) {\n  variant(variantId: $variantId) {\n    id\n    rsIds\n    credibleSets(studyTypes: [gwas], page: {size: $size, index: $index}) {\n      count\n      rows {\n        studyLocusId\n        studyId\n        region\n        finemappingMethod\n        pValueMantissa\n        pValueExponent\n        beta\n        confidence\n        study {\n          id\n          traitFromSource\n          publicationFirstAuthor\n          pubmedId\n          diseases {\n            id\n            name\n          }\n        }\n        l2GPredictions {\n          rows {\n            target {\n              id\n              approvedSymbol\n            }\n            score\n          }\n        }\n      }\n    }\n  }\n}\n",
    "type": "OpenTarget",
    "test_examples": [
      {
        "variantId": "10_112998590_C_T",
        "size": 5
      }
    ],
    "return_schema": {
      "oneOf": [
        {
          "type": "object",
          "properties": {
            "data": {
              "type": "object",
              "properties": {
                "variant": {
                  "type": "object",
                  "properties": {
                    "id": {
                      "type": "string"
                    },
                    "rsIds": {
                      "type": "array",
                      "items": {
                        "type": "string"
                      }
                    },
                    "credibleSets": {
                      "type": "object",
                      "properties": {
                        "count": {
                          "type": "integer"
                        },
                        "rows": {
                          "type": "array",
                          "items": {
                            "type": "object",
                            "properties": {
                              "studyLocusId": {
                                "type": "string"
                              },
                              "studyId": {
                                "type": "string"
                              },
                              "region": {
                                "type": [
                                  "string",
                                  "null"
                                ]
                              },
                              "finemappingMethod": {
                                "type": [
                                  "string",
                                  "null"
                                ]
                              },
                              "pValueMantissa": {
                                "type": [
                                  "number",
                                  "null"
                                ]
                              },
                              "pValueExponent": {
                                "type": [
                                  "integer",
                                  "null"
                                ]
                              },
                              "beta": {
                                "type": [
                                  "number",
                                  "null"
                                ]
                              },
                              "confidence": {
                                "type": [
                                  "string",
                                  "null"
                                ]
                              },
                              "study": {
                                "type": "object",
                                "properties": {
                                  "id": {
                                    "type": "string"
                                  },
                                  "traitFromSource": {
                                    "type": [
                                      "string",
                                      "null"
                                    ]
                                  },
                                  "publicationFirstAuthor": {
                                    "type": [
                                      "string",
                                      "null"
                                    ]
                                  },
                                  "pubmedId": {
                                    "type": [
                                      "string",
                                      "null"
                                    ]
                                  },
                                  "diseases": {
                                    "type": "array",
                                    "items": {
                                      "type": "object",
                                      "properties": {
                                        "id": {
                                          "type": "string"
                                        },
                                        "name": {
                                          "type": "string"
                                        }
                                      }
                                    }
                                  }
                                }
                              },
                              "l2GPredictions": {
                                "type": "object",
                                "properties": {
                                  "rows": {
                                    "type": "array",
                                    "items": {
                                      "type": "object",
                                      "properties": {
                                        "target": {
                                          "type": "object",
                                          "properties": {
                                            "id": {
                                              "type": "string"
                                            },
                                            "approvedSymbol": {
                                              "type": "string"
                                            }
                                          }
                                        },
                                        "score": {
                                          "type": "number"
                                        }
                                      }
                                    }
                                  }
                                }
                              }
                            }
                          }
                        }
                      }
                    }
                  }
                }
              }
            }
          },
          "required": [
            "data"
          ]
        },
        {
          "type": "object",
          "properties": {
            "error": {
              "type": "object"
            }
          },
          "required": [
            "error"
          ]
        }
      ]
    }
