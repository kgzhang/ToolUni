  {
    "name": "OpenTargets_get_gwas_study",
    "description": "Get detailed metadata for a GWAS study from Open Targets Platform, including trait information, sample sizes, publication details, disease mappings, cohorts, LD population structure, and availability of summary statistics. Use GCST accession IDs.",
    "label": [
      "GWAS",
      "Study",
      "Genetics",
      "Open Targets"
    ],
    "parameter": {
      "type": "object",
      "properties": {
        "studyId": {
          "type": "string",
          "description": "GWAS study accession ID (e.g., 'GCST000392' for T1D Barrett et al., 'GCST90029024' for T2D Loh et al.)"
        }
      },
      "required": [
        "studyId"
      ]
    },
    "query_schema": "\nquery gwasStudy($studyId: String!) {\n  study(studyId: $studyId) {\n    id\n    studyType\n    traitFromSource\n    publicationFirstAuthor\n    publicationTitle\n    publicationDate\n    publicationJournal\n    pubmedId\n    nSamples\n    nCases\n    nControls\n    initialSampleSize\n    hasSumstats\n    summarystatsLocation\n    cohorts\n    diseases {\n      id\n      name\n    }\n    ldPopulationStructure {\n      ldPopulation\n      relativeSampleSize\n    }\n  }\n}\n",
    "type": "OpenTarget",
    "test_examples": [
      {
        "studyId": "GCST000392"
      },
      {
        "studyId": "GCST90029024"
      }
    ],
