      "GWAS",
      "Credible Set",
      "Fine-mapping",
      "L2G",
      "Open Targets"
    ],
    "parameter": {
      "type": "object",
      "properties": {
        "studyLocusId": {
          "type": "string",
          "description": "Credible set identifier (studyLocusId), a 32-character hash (e.g., 'b758d8fb10924f5338cbad8d27c7dee8'). Obtain from variant credible sets or study credible sets queries."
