  {
    "name": "Orphanet_search_by_name",
    "description": "Search for rare diseases by exact or partial name match in Orphanet. More precise than keyword search. Returns ORPHA codes and disease names. Supports exact matching mode for disambiguation.",
    "type": "OrphanetTool",
    "parameter": {
      "type": "object",
      "properties": {
        "operation": {
          "type": "string",
          "const": "search_by_name",
          "description": "Operation type (fixed: search_by_name)"
        },
        "name": {
          "type": "string",
          "description": "Disease name to search (e.g., 'Marfan syndrome')"
        },
        "exact": {
          "type": "boolean",
          "description": "If true, match exact name only. Default: false",
          "default": false
        },
        "lang": {
          "type": "string",
          "description": "Language code (default: en)",
          "default": "en"
        }
      },
      "required": [
        "name"
      ]
    },
    "return_schema": {
      "type": "object",
      "properties": {
        "status": {
          "type": "string"
        },
        "data": {
          "type": "object",
          "properties": {
            "results": {
              "type": "array"
            },
            "count": {
              "type": "integer"
            },
            "exact_match": {
              "type": "boolean"
            }
          }
        }
      }
    },
    "test_examples": [
      {
        "name": "Marfan syndrome",
        "exact": true
      }
    ]
  },
  {
    "name": "Orphanet_get_phenotypes",
    "description": "Get HPO (Human Phenotype Ontology) phenotypes associated with a rare disease from Orphanet. Returns HPO terms with their frequency (Very frequent, Frequent, Occasional, Very rare, Excluded) and whether they are diagnostic criteria. Essential for phenotype-driven rare disease diagnosis.",
    "type": "OrphanetTool",
    "parameter": {
      "type": "object",
      "properties": {
        "operation": {
          "type": "string",
          "const": "get_phenotypes",
          "description": "Operation type (fixed: get_phenotypes)"
        },
        "orpha_code": {
          "type": "string",
          "description": "Orphanet ORPHA code (e.g., 558 for Marfan, 586 for Cystic Fibrosis)"
        }
      },
      "required": [
        "orpha_code"
      ]
    },
    "return_schema": {
      "type": "object",
      "properties": {
        "status": {
          "type": "string"
        },
        "data": {
          "type": "object",
          "properties": {
            "orpha_code": {
              "type": "string"
            },
            "preferred_term": {
              "type": "string"
            },
            "phenotypes": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "hpo_id": {
                    "type": "string"
                  },
                  "hpo_term": {
                    "type": "string"
                  },
                  "frequency": {
                    "type": "string"
                  },
                  "diagnostic_criteria": {
                    "type": [
                      "string",
                      "null"
                    ]
                  }
                }
              }
            },
            "phenotype_count": {
              "type": "integer"
            }
          }
        }
      }
    },
    "test_examples": [
      {
        "orpha_code": "558"
      },
      {
        "orpha_code": "586"
      }
    ]
  },
