          "description": "Orphanet ORPHA code"
        },
        "lang": {
          "type": "string",
          "description": "Language code (default: en)",
          "default": "en"
        }
      },
      "required": [
        "orpha_code"
      ]
    },
    "return_schema": {
      "type": "object",
      "properties": {
        "status": {
          "type": "string"
        },
        "data": {
          "type": "object",
          "properties": {
            "orpha_code": {
              "type": "string"
            },
            "classification": {
              "type": "object",
              "description": "Hierarchical classification"
            }
          }
        }
      }
    },
    "test_examples": [
