[
  {
    "name": "Orphanet_search_diseases",
    "description": "Search Orphanet for rare diseases by keyword. Orphanet is the reference portal for rare diseases and orphan drugs. Returns disease names, ORPHA codes, and synonyms. No authentication required. Supports multiple languages (en, fr, de, es, it, pt, pl, nl).",
    "type": "OrphanetTool",
    "parameter": {
      "type": "object",
      "properties": {
        "operation": {
          "type": "string",
          "const": "search_diseases",
          "description": "Operation type (fixed: search_diseases)"
        },
        "query": {
          "type": "string",
          "description": "Search query - disease name or keyword (e.g., 'Marfan', 'muscular dystrophy')"
        },
        "limit": {
          "type": "integer",
          "description": "Maximum number of results to return (default: 20, max: 200). The API may return thousands of fuzzy matches; use this to control output size.",
          "default": 20
        },
        "lang": {
          "type": "string",
          "description": "Language code (en, fr, de, es, it, pt, pl, nl). Default: en",
          "default": "en"
        }
      },
      "required": [
        "query"
      ]
    },
    "return_schema": {
      "type": "object",
      "properties": {
        "status": {
          "type": "string",
          "enum": [
            "success",
            "error"
          ]
        },
        "data": {
          "type": "object",
          "properties": {
            "results": {
              "type": "array",
              "description": "Matching rare diseases"
            },
            "count": {
              "type": "integer",
              "description": "Number of results returned"
            },
            "total_count": {
              "type": "integer",
              "description": "Total matches before truncation"
            },
            "query": {
              "type": "string"
            }
          }
        }
      }
    },
    "test_examples": [
      {
        "query": "Marfan syndrome"
      },
      {
        "query": "muscular dystrophy",
        "lang": "en",
        "limit": 10
      }
    ]
  },
  {
    "name": "Orphanet_get_disease",
    "description": "Get detailed information about a rare disease by ORPHA code. Returns disease name, definition, synonyms, and classification. ORPHA codes are unique Orphanet identifiers (e.g., 558 for Marfan syndrome). No authentication required.",
    "type": "OrphanetTool",
    "parameter": {
      "type": "object",
      "properties": {
        "operation": {
          "type": "string",
          "const": "get_disease",
          "description": "Operation type (fixed: get_disease)"
        },
        "orpha_code": {
          "type": "string",
          "description": "Orphanet ORPHA code (e.g., 558, 166024). Can include ORPHA: prefix."
        },
        "lang": {
          "type": "string",
          "description": "Language code (default: en)",
          "default": "en"
        }
      },
      "required": [
        "orpha_code"
      ]
    },
    "return_schema": {
      "type": "object",
      "properties": {
        "status": {
          "type": "string"
        },
        "data": {
          "type": "object",
          "properties": {
            "ORPHAcode": {
              "type": "string",
              "description": "Orphanet identifier"
            },
            "Preferred term": {
              "type": "string",
              "description": "Official disease name"
            },
            "Definition": {
              "type": "string",
              "description": "Disease definition"
            },
            "Synonyms": {
              "type": "array",
              "description": "Alternative names"
            }
          }
        }
      }
    },
    "test_examples": [
      {
        "orpha_code": "558"
      },
      {
        "orpha_code": "ORPHA:166024"
      }
    ]
  },
  {
    "name": "Orphanet_get_genes",
    "description": "Get genes associated with a rare disease from Orphanet. Returns gene symbols, names, and association types (causative, modifier, susceptibility). Essential for rare disease genetic diagnosis.",
    "type": "OrphanetTool",
    "parameter": {
      "type": "object",
      "properties": {
        "operation": {
          "type": "string",
          "const": "get_genes",
          "description": "Operation type (fixed: get_genes)"
        },
        "orpha_code": {
          "type": "string",
          "description": "Orphanet ORPHA code for the disease"
        }
      },
      "required": [
        "orpha_code"
      ]
    },
    "return_schema": {
      "type": "object",
      "properties": {
        "status": {
          "type": "string"
        },
        "data": {
          "type": "object",
          "properties": {
            "orpha_code": {
              "type": "string"
            },
            "genes": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "Symbol": {
                    "type": "string",
                    "description": "Gene symbol"
                  },
                  "Name": {
                    "type": "string",
                    "description": "Gene name"
                  },
                  "AssociationType": {
                    "type": "string",
                    "description": "Type of gene-disease association"
                  }
                }
              }
            }
          }
        }
      }
    },
    "test_examples": [
      {
        "orpha_code": "558"
      }
    ]
  },
  {
