  {
    "name": "Orphanet_get_gene_diseases",
    "description": "Get rare diseases associated with a gene from Orphanet. Accepts gene symbols (e.g., 'FBN1', 'BRCA1', 'HTT') or gene name keywords (e.g., 'fibrillin', 'huntingtin', 'dystrophin'). Gene symbols are auto-resolved to full names. Returns disease ORPHA codes, gene symbols, association types, and genomic locus information.",
    "type": "OrphanetTool",
    "parameter": {
      "type": "object",
      "properties": {
        "operation": {
          "type": "string",
          "const": "get_gene_diseases",
          "description": "Operation type (fixed: get_gene_diseases)"
        },
        "gene_name": {
          "type": "string",
          "description": "Gene symbol (e.g., 'FBN1', 'BRCA1', 'HTT') or gene name keyword (e.g., 'fibrillin', 'huntingtin'). Symbols are auto-resolved."
        }
      },
      "required": [
        "gene_name"
      ]
    },
    "return_schema": {
      "type": "object",
      "properties": {
        "status": {
          "type": "string"
        },
        "data": {
          "type": "object",
          "properties": {
            "gene_name": {
              "type": "string"
            },
            "diseases": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "orpha_code": {
                    "type": [
                      "string",
                      "integer"
                    ]
                  },
                  "preferred_term": {
                    "type": "string"
                  },
                  "disorder_group": {
                    "type": "string"
                  },
                  "typology": {
                    "type": "string"
                  },
                  "genes": {
                    "type": "array",
                    "items": {
                      "type": "object",
                      "properties": {
                        "symbol": {
                          "type": "string"
                        },
                        "name": {
                          "type": "string"
                        },
                        "association_type": {
                          "type": "string"
                        }
                      }
                    }
                  }
                }
              }
            },
            "disease_count": {
              "type": "integer"
            }
          }
        }
      }
    },
    "test_examples": [
      {
        "gene_name": "FBN1"
      },
      {
        "gene_name": "fibrillin"
      },
      {
        "gene_name": "dystrophin"
      }
    ]
  },
  {
    "name": "Orphanet_get_icd_mapping",
    "description": "Get cross-references between Orphanet ORPHA codes and other medical coding systems (ICD-10, ICD-11, OMIM, SNOMED-CT). Essential for mapping rare disease codes across clinical and research nomenclatures. Returns mapping relationships and validation status.",
    "type": "OrphanetTool",
    "parameter": {
      "type": "object",
      "properties": {
        "operation": {
          "type": "string",
          "const": "get_icd_mapping",
          "description": "Operation type (fixed: get_icd_mapping)"
        },
        "orpha_code": {
          "type": "string",
          "description": "Orphanet ORPHA code (e.g., 558 for Marfan, 586 for Cystic Fibrosis)"
        },
        "coding_system": {
          "type": "string",
          "description": "Which coding system to retrieve: all, icd10, icd11, omim, snomed. Default: all",
          "default": "all"
        },
        "lang": {
          "type": "string",
          "description": "Language code (default: en)",
          "default": "en"
        }
      },
      "required": [
        "orpha_code"
      ]
    },
    "return_schema": {
      "type": "object",
      "properties": {
        "status": {
          "type": "string"
        },
        "data": {
          "type": "object",
          "properties": {
            "orpha_code": {
              "type": "string"
            },
            "mappings": {
              "type": "object",
              "description": "Cross-reference mappings keyed by coding system (ICD10, ICD11, OMIM, SNOMED-CT)"
            }
          }
        }
      }
    },
    "test_examples": [
      {
        "orpha_code": "558"
      },
      {
        "orpha_code": "586",
        "coding_system": "omim"
      }
    ]
  }
]
