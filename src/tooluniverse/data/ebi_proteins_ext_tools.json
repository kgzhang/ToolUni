[
  {
    "name": "EBIProteins_get_mutagenesis",
    "description": "Get mutagenesis experiment data for a protein from the EBI Proteins API. Returns experimentally characterized mutations with their functional effects, including gain/loss of function, binding changes, and structural impacts. Data is curated from UniProtKB with literature evidence. Essential for understanding structure-function relationships. Example: P04637 (TP53) returns 651 mutagenesis annotations showing effects of each mutation on p53 function.",
    "parameter": {
      "type": "object",
      "properties": {
        "accession": {
          "type": "string",
          "description": "UniProt accession. Examples: 'P04637' (TP53/p53), 'P38398' (BRCA1), 'P00533' (EGFR), 'P01308' (Insulin)."
        }
      },
      "required": [
        "accession"
      ]
    },
    "fields": {
      "endpoint": "mutagenesis"
    },
    "type": "EBIProteinsExtTool",
    "test_examples": [
      {
        "accession": "P04637"
      },
      {
        "accession": "P00533"
      }
    ],
    "return_schema": {
      "oneOf": [
        {
          "type": "object",
          "properties": {
            "data": {
              "type": "object",
              "properties": {
                "accession": {
                  "type": [
                    "string",
                    "null"
                  ],
                  "description": "UniProt accession"
                },
                "entry_name": {
                  "type": [
                    "string",
                    "null"
                  ],
                  "description": "UniProt entry name"
                },
                "gene_name": {
                  "type": [
                    "string",
                    "null"
                  ],
                  "description": "Gene name"
                },
                "features": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "properties": {
                      "type": {
                        "type": [
                          "string",
                          "null"
                        ],
                        "description": "Feature type (MUTAGEN)"
                      },
                      "position_start": {
                        "type": [
                          "string",
                          "null"
                        ],
                        "description": "Start position"
                      },
                      "position_end": {
                        "type": [
                          "string",
                          "null"
                        ],
                        "description": "End position"
                      },
                      "original_sequence": {
                        "type": [
                          "string",
                          "null"
                        ],
                        "description": "Mutant sequence"
                      },
                      "description": {
                        "type": [
                          "string",
                          "null"
                        ],
                        "description": "Functional effect of mutation"
                      },
                      "evidences": {
                        "type": "array",
                        "items": {
                          "type": "object"
                        },
                        "description": "Literature evidence (PMID, etc.)"
                      }
                    }
                  },
                  "description": "Mutagenesis features (max 100)"
                },
                "total_features": {
                  "type": "integer",
                  "description": "Total number of mutagenesis features"
                }
              }
            },
            "metadata": {
              "type": "object",
              "properties": {
                "source": {
                  "type": "string"
                },
                "accession": {
                  "type": "string"
                }
              }
            }
          },
          "required": [
            "data"
          ]
        },
        {
          "type": "object",
          "properties": {
            "error": {
              "type": "string"
            }
          },
          "required": [
            "error"
          ]
        }
      ]
    }
