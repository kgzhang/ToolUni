      "type": "object",
      "properties": {
        "accession": {
          "type": "string",
          "description": "UniProt accession. Examples: 'P04637' (TP53), 'P00533' (EGFR), 'P38398' (BRCA1)."
        }
      },
      "required": [
        "accession"
      ]
