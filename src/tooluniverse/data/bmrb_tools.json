[
  {
    "name": "BMRB_get_entry",
    "description": "Get NMR data entry from the Biological Magnetic Resonance Data Bank (BMRB). Returns the full NMR-STAR data for a BMRB entry including chemical shifts, coupling constants, relaxation data, structure restraints, and experimental conditions. BMRB archives NMR spectroscopy data for biological macromolecules (proteins, nucleic acids, carbohydrates) and small molecules. Entry IDs are integers (e.g., 15000 for villin headpiece, 4020 for ubiquitin).",
    "parameter": {
      "type": "object",
      "properties": {
        "entry_id": {
          "type": "string",
          "description": "BMRB entry ID (e.g., '15000', '4020', '11086')"
        }
      },
      "required": [
        "entry_id"
      ]
    },
    "fields": {
      "endpoint": "https://api.bmrb.io/v2/entry/{entry_id}"
    },
    "type": "BaseRESTTool",
    "test_examples": [
      {
        "entry_id": "15000"
      },
      {
        "entry_id": "4020"
      }
    ],
    "return_schema": {
      "oneOf": [
        {
          "type": "object",
          "description": "BMRB entry NMR-STAR data",
          "properties": {
            "entry_id": {
              "type": "string",
              "description": "BMRB entry identifier"
            },
            "saveframes": {
              "type": "object",
              "description": "NMR-STAR saveframes containing experimental data by category"
            }
          }
        },
        {
          "type": "object",
          "properties": {
            "error": {
              "type": "string"
            }
          },
          "required": [
            "error"
          ]
        }
      ]
    }
  },
  {
    "name": "BMRB_get_entry_citation",
    "description": "Get the citation/publication information for a BMRB NMR entry in BibTeX format. Returns author list, title, journal, DOI, and year. Useful for citing NMR data sources.",
    "parameter": {
      "type": "object",
      "properties": {
        "entry_id": {
          "type": "string",
          "description": "BMRB entry ID (e.g., '15000', '4020')"
        }
      },
      "required": [
        "entry_id"
      ]
    },
    "fields": {
      "endpoint": "https://api.bmrb.io/v2/entry/{entry_id}/citation"
    },
    "type": "BaseRESTTool",
    "test_examples": [
      {
        "entry_id": "15000"
      },
      {
        "entry_id": "11086"
      }
    ],
    "return_schema": {
      "oneOf": [
        {
          "type": "string",
          "description": "BibTeX citation string for the BMRB entry"
        },
        {
          "type": "object",
          "properties": {
            "error": {
              "type": "string"
            }
          },
          "required": [
            "error"
          ]
        }
      ]
    }
  },
  {
    "name": "BMRB_search_by_keyword",
    "description": "Search BMRB (Biological Magnetic Resonance Data Bank) entries by keyword or molecule name. Returns matching BMRB entries with their IDs and summary information. Use the 'database' parameter to search either macromolecules (proteins, nucleic acids) or metabolomics small molecules.",
    "parameter": {
      "type": "object",
      "properties": {
        "term": {
          "type": "string",
          "description": "Search term (protein name, molecule name, or keyword). Examples: 'ubiquitin', 'calmodulin', 'insulin'"
        },
        "database": {
          "type": [
            "string",
            "null"
          ],
          "description": "Database to search: 'macromolecules' (proteins/nucleic acids) or 'metabolomics' (small molecules). Default searches both."
        }
      },
      "required": [
        "term"
      ]
    },
    "fields": {
      "endpoint": "https://api.bmrb.io/v2/search/instant"
    },
    "type": "BaseRESTTool",
    "test_examples": [
      {
        "term": "ubiquitin",
        "database": "macromolecules"
      },
      {
        "term": "caffeine",
        "database": "metabolomics"
      }
    ],
    "return_schema": {
      "oneOf": [
        {
          "type": "array",
          "description": "List of matching BMRB entries",
          "items": {
            "type": "object",
            "properties": {
              "bmrb_id": {
                "type": "string",
                "description": "BMRB entry identifier"
              },
              "title": {
                "type": "string"
              },
              "authors": {
                "type": "array"
              },
              "link": {
                "type": "string"
              },
              "sub_date": {
                "type": "string"
              },
              "pdb_ids": {
                "type": "array"
              },
              "formula": {
                "type": "string"
              },
              "smiles": {
                "type": "string"
              }
            }
          }
        },
        {
          "type": "object",
          "properties": {
            "error": {
              "type": "string"
            }
          },
          "required": [
            "error"
          ]
        }
      ]
    }
  },
  {
    "name": "BMRB_get_entries_by_pdb_id",
    "description": "Find BMRB NMR entries associated with a PDB structure. Returns BMRB entry IDs linked to a given PDB accession, with match type (BLAST or author-provided). Useful for finding NMR chemical shift data for a protein with known crystal structure.",
    "parameter": {
      "type": "object",
      "properties": {
        "pdb_id": {
          "type": "string",
          "description": "PDB entry ID (e.g., '1ubq', '1d3z', '2k39')"
        }
      },
      "required": [
        "pdb_id"
      ]
    },
    "fields": {
      "endpoint": "https://api.bmrb.io/v2/search/get_bmrb_ids_from_pdb_id/{pdb_id}"
    },
    "type": "BaseRESTTool",
    "test_examples": [
      {
        "pdb_id": "1ubq"
      },
      {
        "pdb_id": "1d3z"
      }
    ],
    "return_schema": {
      "oneOf": [
        {
          "type": "array",
          "description": "List of BMRB entries linked to the PDB ID",
          "items": {
            "type": "object",
            "properties": {
              "bmrb_id": {
                "type": "string"
              },
              "match_types": {
                "type": "array",
                "items": {
                  "type": "string"
                },
                "description": "How the link was established: 'BLAST Match' or 'Author Provided'"
              }
            }
          }
        },
        {
          "type": "object",
          "properties": {
            "error": {
              "type": "string"
            }
          },
          "required": [
            "error"
          ]
        }
      ]
    }
  },
  {
    "name": "BMRB_get_entries_by_uniprot",
    "description": "Find BMRB NMR entries for a protein using its UniProt accession. Returns NMR data entries associated with the protein, allowing cross-referencing between sequence databases and NMR spectroscopy data.",
    "parameter": {
      "type": "object",
      "properties": {
        "uniprot_id": {
          "type": "string",
          "description": "UniProt accession (e.g., 'P62988' for ubiquitin, 'P0DTD1' for SARS-CoV-2 polyprotein)"
        }
      },
      "required": [
        "uniprot_id"
      ]
    },
    "fields": {
      "endpoint": "https://api.bmrb.io/v2/protein/uniprot/{uniprot_id}"
    },
    "type": "BaseRESTTool",
    "test_examples": [
      {
        "uniprot_id": "P62988"
      },
      {
        "uniprot_id": "P0CG48"
      }
    ],
    "return_schema": {
      "oneOf": [
        {
          "type": "array",
          "description": "List of BMRB entries for the UniProt protein",
          "items": {
            "type": "object",
            "properties": {
              "bmrb_id": {
                "type": "string"
              },
              "pdb_id": {
                "type": "string"
              },
              "link": {
                "type": "string"
              }
            }
          }
        },
        {
          "type": "object",
          "properties": {
            "error": {
              "type": "string"
            }
          },
          "required": [
            "error"
          ]
        }
      ]
    }
  }
]
